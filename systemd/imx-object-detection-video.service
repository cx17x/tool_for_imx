[Unit]
Description=IMX500 Object Detection With Video UDP
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/pi/tool_for_imx
ExecStartPre=/home/pi/tool_for_imx/scripts/wait_for_camera.sh 60
ExecStart=/home/pi/venv/bin/python /home/pi/tool_for_imx/object_detection.py --config /home/pi/tool_for_imx/config/object_detection.json
Restart=always
RestartSec=10
User=pi
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
